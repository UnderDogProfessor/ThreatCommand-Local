# ThreatCommand Local configuration. Store this file locally as .env.
# All web ports are mapped to 127.0.0.1 by docker-compose.yml.
POSTGRES_DB=threatcommand
POSTGRES_USER=threatcommand
POSTGRES_PASSWORD=replace-with-a-unique-long-local-password

# Default is Manual Sync. Valid values: offline, manual, scheduled.
NETWORK_MODE=manual

# Ollama is optional and must point to a local service only.
OLLAMA_ENDPOINT=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=
OLLAMA_EMBEDDING_MODEL=

# Optional Phase 4 external AI. Disabled by default: no prompt, local context, or source text
# is sent to a provider unless EXTERNAL_AI_ENABLED=true and you select it in Settings.
# Keep the key only in your local .env; do not paste it into the dashboard or commit it.
# Supported provider choices: ollama, openai, openai-compatible.
AI_PROVIDER=ollama
EXTERNAL_AI_ENABLED=false
EXTERNAL_AI_BASE_URL=https://api.openai.com/v1
EXTERNAL_AI_API_KEY=
EXTERNAL_AI_MODEL=

# Optional comma-separated HTTPS connector host allowlist. When empty, a connector may only
# use its configured hostname (or its www. variant); redirects to unrelated hosts are blocked.
CONNECTOR_ALLOWLIST=
