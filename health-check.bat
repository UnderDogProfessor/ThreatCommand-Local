@echo off
powershell -NoProfile -Command "$ErrorActionPreference='Stop'; $deadline=(Get-Date).AddSeconds(45); while ((Get-Date) -lt $deadline) { try { $front=Invoke-WebRequest -UseBasicParsing http://127.0.0.1:3000 -TimeoutSec 5; $api=Invoke-RestMethod http://127.0.0.1:8000/api/health -TimeoutSec 5; if ($front.StatusCode -eq 200 -and $api.status -eq 'healthy') { Write-Output 'Healthy: frontend and local API responded on localhost.'; exit 0 } } catch { } Start-Sleep -Seconds 2 }; Write-Error 'ThreatCommand did not become healthy within 45 seconds. Check Docker Desktop, then run docker compose logs.'; exit 1"
